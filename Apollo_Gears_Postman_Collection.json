          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Clear old tokens before login",
                  "pm.collectionVariables.set('token', '');",
                  "pm.collectionVariables.set('refreshToken', '');",
                  "console.log('Old tokens cleared. Logging in...');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "",
                  "// Auto-save access token",
                  "if (json.data && json.data.accessToken) {",
                  "  pm.collectionVariables.set('token', json.data.accessToken);",
                  "  console.log('Access token saved!');",
                  "}",
                  "",
                  "// Auto-save refresh token",
                  "if (json.data && json.data.refreshToken) {",
                  "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "  console.log('Refresh token saved!');",
                  "}",
                  "",
                  "// Auto-save userId",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('userId', json.data.id);",
                  "  console.log('userId saved: ' + json.data.id);",
                  "}",
                  "",
                  "pm.test('Token exists in response', function() {",
                  "  pm.expect(json.data).to.have.property('accessToken');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
